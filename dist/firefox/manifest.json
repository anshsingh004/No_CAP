{
  "manifest_version": 2,
  "name": "No Cap – Ethical Coding Assistant",
  "version": "1.1.0",
  "description": "Track your coding integrity on LeetCode. Build real discipline.",
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
    "default_title": "No Cap – Integrity Tracker"
  },
  "background": {
    "scripts": ["lib/browser-polyfill.js", "background/background-mv2.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/contest/*"
      ],
      "js": ["lib/browser-polyfill.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "tabs", "activeTab", "notifications", "https://leetcode.com/*"],
  "browser_specific_settings": {
    "gecko": { "id": "nocap@ethical-coding.dev", "strict_min_version": "91.0" }
  }
}
